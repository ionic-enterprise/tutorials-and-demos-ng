{
  "name": "demo-pwa",
  "description": "A Progressive Web App example",
  "version": "0.0.1",
  "author": "Ionic Framework",
  "homepage": "https://ionicframework.com/",
  "scripts": {
    "android": "cap open android",
    "assets": "capacitor-assets generate --iconBackgroundColor '#f1ebe1' --splashBackgroundColor '#f1ebe1' --iconBackgroundColorDark '#110b00' --splashBackgroundColorDark '#110b00'",
    "build": "ng build --configuration production && cap sync",
    "ios": "cap open ios",
    "lint": "ng lint",
    "ng": "ng",
    "start": "ng serve --port=8100",
    "test": "ng test --no-watch",
    "test:debug": "ng test --browsers=Chrome",
    "test:dev": "ng test",
    "watch": "ng build --watch --configuration development"
  },
  "private": true,
  "dependencies": {
    "@angular/common": "^20.3.18",
    "@angular/core": "^20.3.18",
    "@angular/forms": "^20.3.18",
    "@angular/platform-browser": "^20.3.18",
    "@angular/platform-browser-dynamic": "^20.3.18",
    "@angular/router": "^20.3.18",
    "@angular/service-worker": "^20.3.18",
    "@capacitor/android": "^8.3.0",
    "@capacitor/app": "^8.1.0",
    "@capacitor/core": "^8.3.0",
    "@capacitor/haptics": "^8.0.2",
    "@capacitor/ios": "^8.3.0",
    "@capacitor/keyboard": "^8.0.2",
    "@capacitor/preferences": "^8.0.1",
    "@capacitor/privacy-screen": "^2.0.1",
    "@capacitor/share": "^8.0.1",
    "@ionic-enterprise/auth": "8.0.0",
    "@ionic-enterprise/identity-vault": "~6.0.6",
    "@ionic/angular": "8.8.3",
    "ionicons": "~8.0.13",
    "rxjs": "~7.8.2",
    "tslib": "^2.8.1",
    "zone.js": "~0.15.1"
  },
  "devDependencies": {
    "@angular/build": "^20.3.22",
    "@angular/cli": "^20.3.22",
    "@angular/compiler": "^20.3.18",
    "@angular/compiler-cli": "^20.3.18",
    "@angular/language-service": "^20.3.18",
    "@capacitor/assets": "~3.0.5",
    "@capacitor/cli": "^8.3.0",
    "@ionic/angular-toolkit": "~12.3.0",
    "@types/jasmine": "~5.1.15",
    "@types/node": "^24.12.2",
    "angular-eslint": "^20.7.0",
    "eslint": "^9.39.4",
    "jasmine-core": "~5.9.0",
    "jasmine-spec-reporter": "~7.0.0",
    "karma": "~6.4.4",
    "karma-chrome-launcher": "^3.2.0",
    "karma-coverage": "~2.2.1",
    "karma-coverage-istanbul-reporter": "~3.0.3",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "ts-node": "~10.9.2",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.58.0"
  }
}
